# ─────────────────────────────────────────────────────────────────────────────
# Sunrise full-stack deployment — environment template.
#   cp .env.example .env   then edit the "change me" values.
# `.env` is gitignored; this file is committed and MUST NOT hold real secrets.
#
# Generate strong secrets for production, e.g.:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ===== Postgres (shared by cottonid / hydra / sunrise) =======================
POSTGRES_USER=cotton
POSTGRES_PASSWORD=dev-change-me-postgres
POSTGRES_DB=cottonid

# ===== Hydra (OIDC engine) — REQUIRED secrets ================================
# 32+ chars each. CHANGE in production.
HYDRA_SYSTEM_SECRET=dev-change-me-hydra-system-secret-0123456789
HYDRA_COOKIE_SECRET=dev-change-me-hydra-cookie-secret-0123456789
# Public OIDC issuer as seen by the browser.
HYDRA_PUBLIC_URL=http://localhost:4444
# Internal issuer (used inside the Docker network and as the token "iss" claim).
HYDRA_INTERNAL_URL=http://hydra:4444
HYDRA_PUBLIC_PORT=4444
HYDRA_ADMIN_PORT=4445
# Browser origins allowed to call Hydra's public API (PKCE token exchange).
HYDRA_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8088

# ===== cotton-id (SSO) ========================================================
COTTON_ENV=development
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000
ADMIN_API_KEY=dev-change-me-admin-key-0123456789abcdef
BACKEND_PORT=8080
FRONTEND_PORT=3000
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGINS=http://localhost:3000,http://localhost:8088

# ===== Sunrise messenger backend ==============================================
SUNRISE_PORT=6060
# OIDC validation on the Sunrise side. Must match the token "iss" (Hydra self-issuer)
# and be reachable from the sunrise container for JWKS.
SUNRISE_OIDC_ISSUER=http://hydra:4444/
SUNRISE_OIDC_DISCOVERY_ISSUER=http://hydra:4444/
OIDC_CLIENT_ID=sunrise-messenger

# ===== LiveKit (SFU group calls) — REQUIRED secret ===========================
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=dev-change-me-livekit-secret-0123456789abcdef
LIVEKIT_PORT=7880
# URL the browser (and the token response) use to reach LiveKit.
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# Access-token lifetime in minutes (default 360). Applies to /v0/livekit/token.
LIVEKIT_TOKEN_TTL_MIN=360

# ===== Web client (Vite, baked at build time) =================================
WEB_PORT=8088
VITE_HOST=localhost:6060
VITE_API_KEY=AQEAAAABAAD_rAp4DJh05a1HAwFT3A6K
VITE_TLS=false
VITE_OIDC_ISSUER=http://localhost:4444/
VITE_OIDC_REDIRECT=http://localhost:8088/

# ===== Edge / single-port (optional `edge` profile) ==========================
# Domain Caddy serves on. For a real domain Caddy auto-provisions TLS on :443.
# With this, only 443 (+ LiveKit media 7881/TCP, 7882/UDP) needs to be public.
CADDY_DOMAIN=localhost

# ===== Misc ===================================================================
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# WITHOUT SSO: leave SUNRISE_OIDC_ISSUER empty (the oidc scheme auto-disables) and
# start only the messenger services:
#   docker compose up -d --build postgres sunrise livekit web
# Login is then login/password (basic). No Hydra/cotton-id, no ports 3000/4444/4445/8080.
#   SUNRISE_OIDC_ISSUER=
# ─────────────────────────────────────────────────────────────────────────────
