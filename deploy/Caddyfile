# Single-port (443) edge. The PRIMARY client is the mature Tinode/Sunrise React app,
# which the Sunrise backend serves at "/" on the same origin as the API (/v0/*) — so it
# auto-detects the server and works with zero config. LiveKit signaling shares :443 too.
#
# Set CADDY_DOMAIN in .env (defaults to localhost). Only 443/TCP needs to be public for the
# app — PLUS LiveKit media 7881/TCP + 7882/UDP (WebRTC media is not HTTP, can't be proxied).

{$CADDY_DOMAIN:localhost} {
	encode zstd gzip

	# LiveKit SFU: signaling (/rtc) + API (/twirp). Must precede the catch-all.
	@livekit path /rtc /rtc/* /twirp/*
	reverse_proxy @livekit livekit:7880

	# Everything else → Sunrise backend: it serves the React client at "/" AND the
	# WS chat (/v0/channels), files (/v0/file), token (/v0/livekit/token) on one origin.
	reverse_proxy sunrise:6060
}

