# Sunrise web client configuration (Vite). Copy to `.env` and adjust.
# All values are build-time; rebuild after changing.

# Messenger backend (Sunrise/Tinode)
VITE_HOST=localhost:6060
VITE_API_KEY=AQEAAAABAAD_rAp4DJh05a1HAwFT3A6K
VITE_APP_NAME=SunriseWeb
VITE_TLS=false

# SSO (cotton-id / Ory Hydra)
VITE_OIDC_ISSUER=http://localhost:4444/
VITE_OIDC_CLIENT_ID=sunrise-messenger
VITE_OIDC_SCOPES=openid profile email
# Defaults to window.location.origin + '/' when unset.
# VITE_OIDC_REDIRECT=http://localhost:5173/
