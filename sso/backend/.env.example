# cotton-id backend configuration (env vars). Copy to .env and fill in real
# values for local development. NEVER commit real secrets. Every variable the
# backend reads is documented here (build-contract §5).

# Environment profile: development | production | test.
# production tightens validation (no weak secrets, Secure cookies, https).
COTTON_ENV=development

# HTTP listen address for the backend.
HTTP_ADDR=:8080

# Backend's externally-reachable base URL (used for Swagger + reset links host).
PUBLIC_BASE_URL=http://localhost:8080

# SPA origin, used for CORS and browser redirects.
FRONTEND_BASE_URL=http://localhost:3000

# PostgreSQL DSN for the cotton-id database (Hydra uses a separate DB).
DATABASE_URL=postgres://cotton:cotton@localhost:5432/cottonid?sslmode=disable

# Ory Hydra endpoints. Admin is internal-only; public is the OIDC issuer.
HYDRA_ADMIN_URL=http://localhost:4445
HYDRA_PUBLIC_URL=http://localhost:4444

# Cookie names.
SESSION_COOKIE_NAME=cid_session
CSRF_COOKIE_NAME=cid_csrf

# Admin API key authorizing /api/v1/admin/* (X-Admin-Key header).
# REQUIRED in production; must be 32+ random characters and not a known-weak value.
ADMIN_API_KEY=dev-admin-key-change-me

# Session lifetimes.
SESSION_TTL_HOURS=24
SESSION_REMEMBER_DAYS=30

# Password-reset token lifetime.
PASSWORD_RESET_TTL_MINUTES=30

# Rate limiting for auth endpoints (token bucket): refill rate and burst.
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

# Consecutive failed logins per account before incremental-backoff lockout.
LOGIN_LOCKOUT_THRESHOLD=5

# Trusted reverse-proxy CIDRs (comma-separated) whose X-Forwarded-For is honored
# when resolving the client IP. EMPTY = ignore XFF, use the direct peer IP
# (fail-safe). Set this only when running behind a known proxy (e.g. 10.0.0.0/8).
TRUSTED_PROXIES=

# Logging level: debug | info | warn | error.
LOG_LEVEL=info

# Force the Secure attribute on cookies. false for plain-HTTP local dev;
# MUST be true in production.
COOKIE_SECURE=false

# ===== Social login (OAuth2 / OIDC providers) ================================
# Per-provider OAuth app credentials. A provider is ENABLED only when BOTH its
# client id and secret are set; leaving them empty (the default) DISABLES that
# provider — its button is hidden in the UI and its start/callback endpoints
# return "provider not enabled". The OAuth redirect URI to register with each
# provider is PUBLIC_BASE_URL + /api/v1/auth/social/<provider>/callback.
# See docs/SOCIAL_LOGIN.md for how to register each OAuth app. (Apple is not
# supported — see that doc.) NEVER commit real client secrets.

# Google (OIDC). https://console.cloud.google.com → APIs & Services → Credentials.
SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=

# GitHub. https://github.com/settings/developers → OAuth Apps.
SOCIAL_GITHUB_CLIENT_ID=
SOCIAL_GITHUB_CLIENT_SECRET=

# VK (vk.com / VK ID, https://id.vk.com). VK ID is a PKCE public client, so the
# CLIENT_ID alone ENABLES it; the secret is optional (leave it empty for the
# PKCE flow). VK emails are treated as unverified (never auto-link to an account).
SOCIAL_VK_CLIENT_ID=
SOCIAL_VK_CLIENT_SECRET=

# Yandex (ya.ru). https://oauth.yandex.com → your app's ID and password.
SOCIAL_YANDEX_CLIENT_ID=
SOCIAL_YANDEX_CLIENT_SECRET=

# ===== Passkeys (WebAuthn / FIDO2) ===========================================
# Relying-party (RP) configuration for passwordless passkey sign-in. The RP ID
# MUST be a registrable suffix of every allowed origin (e.g. RP_ID=id.example.com
# for origin https://id.example.com), or browsers refuse the ceremony. The dev
# defaults below match the local SPA at http://localhost:3000. See docs/PASSKEYS.md.
#
# ⚠️  PRODUCTION: set WEBAUTHN_RP_ID to your real registrable domain (e.g.
#     id.example.com) and WEBAUTHN_RP_ORIGINS to the https origin(s) the SPA is
#     served from (e.g. https://id.example.com). An RP-ID/origin mismatch breaks
#     every passkey ceremony.

# The registrable domain that owns the passkeys. localhost for dev.
WEBAUTHN_RP_ID=localhost

# Human-readable RP name some authenticators show during registration.
WEBAUTHN_RP_DISPLAY_NAME=cotton-id

# Comma-separated allowed origins (scheme + host + port). The RP ID must be a
# registrable suffix of each. Dev default is the local SPA origin.
WEBAUTHN_RP_ORIGINS=http://localhost:3000

# ===== Email delivery (SMTP) =================================================
# Transactional email transport (password reset, login notifications, admin
# "message user"). When SMTP_HOST is EMPTY (the default), the backend uses the
# development LogMailer — emails are logged, not sent — so local dev needs no
# mail server. Set SMTP_HOST (and the rest) to enable real SMTP delivery. Sends
# are best-effort: a delivery failure is logged and NEVER blocks the user action.
#
# SMTP_PORT: 587 (STARTTLS) | 465 (implicit TLS) | 25. SMTP_FROM is the From
# address, e.g. "cotton-id <no-reply@example.com>". NEVER commit a real password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# ===== OAuth / passkey ceremony-state signing key ============================
# Shared HMAC signing key for the social-login (cid_oauth) and passkey (cid_wa)
# ceremony-state cookies. EMPTY (the default) = a per-process random key, fine
# for a SINGLE instance but a ceremony begun on one replica can't finish on
# another. To run MULTIPLE backend replicas, set the SAME 32+ byte random value
# on every replica (the social and passkey keys are derived from it via HKDF with
# distinct labels). Generate with: openssl rand -hex 32. NEVER commit a real key.
OAUTH_STATE_KEY=
