{
  "__comment": "cotton-id operational dashboard. Provisioned read-only by deploy/grafana/provisioning/dashboards/dashboards.yml. PromQL targets the metrics the backend exposes at /metrics: http_request_duration_seconds (route,method,status), cotton_login_attempts_total (result=success|failure|locked), cotton_signup_attempts_total (result), cotton_consent_decisions_total (decision), and the synthetic up{job}. The lockout panel uses cotton_login_attempts_total{result=\"locked\"}; the backend also exposes the dedicated counters cotton_account_lockouts_total, cotton_social_logins_total (provider,result) and cotton_passkey_logins_total (result) for per-provider/per-method breakdowns.",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cotton-id", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "cotton-id — Overview",
  "uid": "cotton-id-overview",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Service health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Backend up (scrape)",
      "description": "Synthetic `up` sample for the backend scrape target: 1 = Prometheus is scraping /metrics, 0 = the backend is unreachable. Mirrors the TargetDown alert.",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "max(up{job=\"cotton-id-backend\"})",
          "instant": true,
          "legendFormat": "up"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Request rate (req/s)",
      "description": "Total HTTP request throughput across all routes over the last 5m.",
      "id": 2,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "5xx error ratio",
      "description": "Fraction of requests answered with a 5xx over 5m. Mirrors the HighHTTP5xxRate alert (fires > 5%).",
      "id": 3,
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_request_duration_seconds_count[5m])), 1e-9)",
          "legendFormat": "5xx ratio"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "p95 latency (all routes)",
      "description": "95th-percentile request latency across all routes over 5m.",
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "HTTP traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Request rate by route",
      "description": "Per-route request throughput (req/s) over 5m. The `route` label is the chi route pattern, so cardinality stays bounded.",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "p95 latency by route",
      "description": "Per-route 95th-percentile latency over 5m, computed from the request-duration histogram buckets.",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Responses by status class",
      "description": "Request rate grouped by HTTP status family (2xx/3xx/4xx/5xx) over 5m. A rising 5xx band indicates a backend fault.",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "showPoints": "never", "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "5xx error rate",
      "description": "Absolute rate of 5xx responses (req/s) over 5m, broken out by route. Backs the HighHTTP5xxRate alert.",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count{status=~\"5..\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Authentication",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 102,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Login success / failure / lockout",
      "description": "Login attempt rate by result over 5m. `success`/`failure`/`locked` come from cotton_login_attempts_total{result}. A failure/locked surge backs the AuthFailureSpike and LoginLockoutSurge alerts.",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(cotton_login_attempts_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "locked" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "type": "stat",
      "title": "Login failure ratio (5m)",
      "description": "Share of login attempts that failed or were locked out over 5m. Backs the AuthFailureSpike alert (fires > 50%).",
      "id": 10,
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(cotton_login_attempts_total{result=~\"failure|locked\"}[5m])) / clamp_min(sum(rate(cotton_login_attempts_total[5m])), 1e-9)",
          "legendFormat": "failure ratio"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Lockouts (5m rate)",
      "description": "Rate of account lockouts over 5m, from cotton_login_attempts_total{result=\"locked\"}. Backs the LoginLockoutSurge alert.",
      "id": 11,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(cotton_login_attempts_total{result=\"locked\"}[5m]))",
          "legendFormat": "lockouts/s"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Onboarding & consent",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 103,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Signups",
      "description": "Signup attempt rate by result over 5m, from cotton_signup_attempts_total{result=success|failure}.",
      "id": 12,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(cotton_signup_attempts_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },
    {
      "type": "stat",
      "title": "Signups (last 24h)",
      "description": "Total successful signups over the last 24h.",
      "id": 13,
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(increase(cotton_signup_attempts_total{result=\"success\"}[24h]))",
          "legendFormat": "signups"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Consent decisions",
      "description": "OIDC consent decision rate by outcome over 5m, from cotton_consent_decisions_total{decision=accept|reject}.",
      "id": 14,
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(rate(cotton_consent_decisions_total[5m])) by (decision)",
          "legendFormat": "{{decision}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "accept" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "reject" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "type": "stat",
      "title": "Consent grants (last 24h)",
      "description": "Total accepted OIDC consent decisions over the last 24h.",
      "id": 15,
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cotton-id-prometheus" },
          "expr": "sum(increase(cotton_consent_decisions_total{decision=\"accept\"}[24h]))",
          "legendFormat": "grants"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      }
    }
  ]
}
