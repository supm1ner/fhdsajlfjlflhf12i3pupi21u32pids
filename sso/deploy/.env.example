# ─────────────────────────────────────────────────────────────────────────────
# cotton-id — environment template (Docker Compose)
#
# Copy to `deploy/.env` and adjust. `.env` is gitignored; THIS file (.env.example)
# is committed and MUST NOT contain real secrets.
#
#   cp deploy/.env.example deploy/.env
#
# ⚠️  PRODUCTION: every value marked "FAKE — change me" below is a known-insecure
#     development placeholder. The backend refuses to start in COTTON_ENV=production
#     with weak/default secrets (design.md D11), and Hydra must be fronted by TLS.
#     Generate real secrets, e.g.:
#         openssl rand -hex 32       # ADMIN_API_KEY, HYDRA_*_SECRET
# ─────────────────────────────────────────────────────────────────────────────

# ===== Runtime mode ==========================================================
# development | production. production forbids weak secrets and weak cookie flags.
COTTON_ENV=development

# ===== Backend (contract §5) =================================================
HTTP_ADDR=:8080
# The backend's externally-reachable base URL (used to build OIDC redirect URLs).
PUBLIC_BASE_URL=http://localhost:8080
# The SPA origin the backend redirects the browser to during login/consent.
FRONTEND_BASE_URL=http://localhost:3000

# cotton-id application database (separate from Hydra's DB, same Postgres).
DATABASE_URL=postgres://cotton:cotton@postgres:5432/cottonid?sslmode=disable

# Hydra endpoints as seen FROM the backend / browser.
HYDRA_ADMIN_URL=http://hydra:4445
HYDRA_PUBLIC_URL=http://localhost:4444

# Cookie names.
SESSION_COOKIE_NAME=cid_session
CSRF_COOKIE_NAME=cid_csrf

# Admin API key guarding /api/v1/admin/* (contract §3). 32+ random chars in prod.
# FAKE — change me in production.
ADMIN_API_KEY=dev-insecure-admin-key-change-me-0123456789

# Session + token lifetimes.
SESSION_TTL_HOURS=24
SESSION_REMEMBER_DAYS=30
PASSWORD_RESET_TTL_MINUTES=30

# Per-IP / per-account token-bucket limits on auth endpoints.
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

# Consecutive failed logins per account before incremental-backoff lockout.
LOGIN_LOCKOUT_THRESHOLD=5

# Trusted reverse-proxy CIDRs (comma-separated) whose X-Forwarded-For is honored
# when resolving the client IP. EMPTY = ignore XFF and use the direct peer IP
# (fail-safe). Set to your proxy network (e.g. 10.0.0.0/8) when behind a proxy.
TRUSTED_PROXIES=

# Logging.
LOG_LEVEL=info

# Force the Secure attribute on cookies. MUST be true in production (HTTPS).
COOKIE_SECURE=false

# ===== Social login (OAuth2 / OIDC providers) ================================
# Per-provider OAuth app credentials. A provider is ENABLED only when BOTH its
# client id and secret are set; leaving them empty (the default) DISABLES that
# provider — its button is hidden in the UI and its start/callback endpoints
# return "provider not enabled". The OAuth redirect URI to register with each
# provider is PUBLIC_BASE_URL + /api/v1/auth/social/<provider>/callback.
# See docs/SOCIAL_LOGIN.md for how to register each OAuth app. (Apple is not
# supported — see that doc.) NEVER commit real client secrets.

# Google (OIDC). https://console.cloud.google.com → APIs & Services → Credentials.
SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=

# GitHub. https://github.com/settings/developers → OAuth Apps.
SOCIAL_GITHUB_CLIENT_ID=
SOCIAL_GITHUB_CLIENT_SECRET=

# VK (vk.com / VK ID, https://id.vk.com). PKCE public client — CLIENT_ID alone
# enables it; the secret is optional. VK emails are treated as unverified.
SOCIAL_VK_CLIENT_ID=
SOCIAL_VK_CLIENT_SECRET=

# Yandex (ya.ru). https://oauth.yandex.com → your app's ID and password.
SOCIAL_YANDEX_CLIENT_ID=
SOCIAL_YANDEX_CLIENT_SECRET=

# ===== Passkeys (WebAuthn / FIDO2) ===========================================
# Relying-party (RP) configuration for passwordless passkey sign-in. The RP ID
# MUST be a registrable suffix of every allowed origin (e.g. RP_ID=id.example.com
# for origin https://id.example.com), or browsers refuse the ceremony. The dev
# defaults below match the local SPA at http://localhost:3000. See docs/PASSKEYS.md.
#
# ⚠️  PRODUCTION: set WEBAUTHN_RP_ID to your real registrable domain (e.g.
#     id.example.com) and WEBAUTHN_RP_ORIGINS to the https origin(s) the SPA is
#     served from (e.g. https://id.example.com). An RP-ID/origin mismatch breaks
#     every passkey ceremony.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_DISPLAY_NAME=cotton-id
WEBAUTHN_RP_ORIGINS=http://localhost:3000

# ===== Email delivery (SMTP) =================================================
# Transactional email transport for password-reset, login-notification, and the
# admin "message user" action. When SMTP_HOST is EMPTY (the default), the backend
# uses the development LogMailer — emails are written to the log, not sent — so
# local dev needs no mail server. Set SMTP_HOST (and the rest) to enable real
# delivery via SMTP. Sends are best-effort: a delivery failure is logged and
# NEVER blocks or fails the originating user action.
#
# SMTP_HOST   — mail server hostname; empty = dev LogMailer (no real send).
# SMTP_PORT   — 587 (STARTTLS, typical) or 465 (implicit TLS) or 25.
# SMTP_USERNAME / SMTP_PASSWORD — SMTP auth credentials (leave empty for none).
# SMTP_FROM   — the From address, e.g. "cotton-id <no-reply@example.com>".
# SMTP_STARTTLS — upgrade the connection with STARTTLS (true for port 587).
# NEVER commit a real SMTP password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# ===== OAuth / passkey ceremony-state signing key ============================
# Shared HMAC signing key for the social-login (cid_oauth) and passkey (cid_wa)
# ceremony-state cookies. EMPTY (the default) = each backend process generates a
# random key at startup — fine for a SINGLE instance, but a ceremony begun on one
# replica cannot be completed on another (the signatures won't validate). To run
# MULTIPLE backend replicas, set this to the SAME 32+ byte random value on every
# replica so they all agree; the social and passkey cookie keys are derived from
# it via HKDF with distinct labels. Generate with: openssl rand -hex 32.
# NEVER commit a real key.
OAUTH_STATE_KEY=

# ===== Account self-service (profile images) =================================
# Hard upper bounds on profile-image uploads (avatar + banner), in kilobytes.
# Images are stored as bounded blobs in Postgres (no object store), so these caps
# keep rows small and blunt decompression/abuse — an upload over the cap, or whose
# content-type/magic bytes are not png/jpeg/webp, is rejected. NOT secrets; safe
# dev defaults. Raise cautiously (storage + memory cost). See docs/ACCOUNT.md.
ACCOUNT_AVATAR_MAX_KB=512
ACCOUNT_BANNER_MAX_KB=1024

# ===== Postgres ==============================================================
# Used by the postgres service and referenced by DATABASE_URL / HYDRA_DSN above.
POSTGRES_USER=cotton
# FAKE — change me in production.
POSTGRES_PASSWORD=cotton
POSTGRES_DB=cottonid

# ===== Hydra =================================================================
# Hydra's OWN database DSN (the `hydra` DB created by deploy/postgres/init).
HYDRA_DSN=postgres://cotton:cotton@postgres:5432/hydra?sslmode=disable&max_conns=8&max_idle_conns=4

# Hydra secrets — injected via env, never written to a committed config file.
# SECRETS_SYSTEM signs/encrypts persisted data; rotating it invalidates state.
# Must be 16+ chars. FAKE — change me in production.
HYDRA_SYSTEM_SECRET=dev-insecure-hydra-system-secret-change-me
HYDRA_COOKIE_SECRET=dev-insecure-hydra-cookie-secret-change-me

# CORS origins Hydra's public API accepts (comma-separated).
HYDRA_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===== Demo seed (dev profile only) ==========================================
# Consumed by the `seed` one-shot to register a demo relying-party client.
DEMO_CLIENT_NAME=Demo Relying Party
DEMO_CLIENT_TYPE=public
DEMO_CLIENT_REDIRECT_URI=http://localhost:3000/callback

# ===== Observability (profile: observability) ================================
# Grafana admin credentials, used ONLY when the `observability` profile is up
# (docker compose --profile observability up). The password has NO default in
# compose, so the profile refuses to start with Grafana's well-known default
# admin/admin. Required only for the observability profile; ignored otherwise.
# Generate a strong value, e.g. openssl rand -base64 24. NEVER commit a real one.
GRAFANA_ADMIN_USER=admin
# FAKE — change me before exposing Grafana.
GRAFANA_ADMIN_PASSWORD=dev-insecure-grafana-password-change-me

# ===== Host port mappings ====================================================
# Change only if a port is already taken on the host (contract §6 defaults).
BACKEND_PORT=8080
FRONTEND_PORT=3000
HYDRA_PUBLIC_PORT=4444
HYDRA_ADMIN_PORT=4445
PROMETHEUS_PORT=9090
# Grafana host port (observability profile). 3001 to avoid the frontend on 3000.
GRAFANA_PORT=3001
